# --- CONFIGURAÇÃO DE AMBIENTE (PRODUÇÃO / VPS HOSTINGER) ---
# Domínio Principal
DOMAIN_NAME=seudominio.com.br

# Email para requisição dos Certificados SSL (Let's Encrypt)
SSL_EMAIL=seu_email@seudominio.com.br

# --- N8N ---
N8N_SUBDOMAIN=flow
N8N_PROTOCOL=https
N8N_ENCRYPTION_KEY=NUNCA_PERCA_ESTA_CHAVE_DE_ENCRIPTACAO

# --- EVOLUTION API ---
EVOLUTION_API_SUBDOMAIN=api
AUTHENTICATION_API_KEY=CHAVE_GLOBAL_DA_EVOLUTION_AQUI

# --- NOCODB ---
NOCODB_SUBDOMAIN=leads

# --- CHATWOOT ---
CHATWOOT_SUBDOMAIN=chat
CHATWOOT_SECRET_KEY_BASE=CHAVE_SECRETA_ALEATORIA_PARA_SESSAO

# --- BANCO DE DADOS (POSTGRES) ---
POSTGRES_USER=n8n
POSTGRES_PASSWORD=SENHA_FORTE_DO_BANCO
POSTGRES_DB=n8n_data

# --- REDIS ---
# Opcional, se quiser senha no Redis descomente aqui e no docker-compose
# REDIS_PASSWORD=senha_rediss
